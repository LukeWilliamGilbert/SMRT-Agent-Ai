      ],
      "parameters": {
        "jsCode": "// GHL response shape: {conversations: [...], total, traceId}\nconst convs = $input.first().json.conversations || [];\nconst startMs = $('Set Backfill Window').first().json.start_ms;\nconst endMs = $('Set Backfill Window').first().json.end_ms;\n\n// Filter conversations whose lastMessageDate falls in the window\nconst inWindow = convs.filter(c => {\n  const ts = c.lastMessageDate || c.dateUpdated;\n  if (!ts) return false;\n  const ms = typeof ts === 'number' ? ts : new Date(ts).getTime();\n  return ms >=\u2026[TRUNCATED]"
      },
      "notes": "Filters conversations whose last activity was in our backfill window."
    },
