      ],
      "parameters": {
        "jsCode": "// n8n 2.x safe: uses $input only \u2014 no $() calls\nconst { pipelines: pipelinesRaw, location_id: locationId } = $input.first().json;\nconst pipelines = Array.isArray(pipelinesRaw) ? pipelinesRaw : [];\n\nfunction findPipeline(list, keywords) {\n  return list.find(p => keywords.some(k => p.name.toLowerCase().includes(k.toLowerCase())));\n}\n\nfunction buildStageMap(stages) {\n  const map = {};\n  if (!stages) return map;\n  for (const s of stages) {\n    const name = s.name.toUpperCase().replace(/[^A-Z0-9_]/g\u2026[TRUNCATED]"
      }
